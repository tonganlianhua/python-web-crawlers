# Python Web Crawlers 环境变量配置

# 应用配置
APP_NAME=python-web-crawlers
APP_VERSION=1.0.0
APP_ENV=production
DEBUG=false

# 数据库配置
DATABASE_URL=postgresql://crawler:crawler123@postgres:5432/crawler_db
POSTGRES_USER=crawler
POSTGRES_PASSWORD=crawler123
POSTGRES_DB=crawler_db

# Redis配置
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# 代理配置
PROXY_ENABLED=false
PROXY_URL=http://127.0.0.1:7890
PROXY_USERNAME=
PROXY_PASSWORD=

# 请求配置
REQUEST_TIMEOUT=30
REQUEST_DELAY=1.0
REQUEST_RETRY=3
RATE_LIMIT=10

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=/app/logs/crawler.log
LOG_FORMAT=json

# 数据存储
DATA_DIR=/app/data
SAVE_FORMAT=json
BATCH_SIZE=100
COMPRESS_DATA=true

# API密钥（如果需要）
OPENWEATHER_API_KEY=
ALPHAVANTAGE_API_KEY=
GITHUB_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=

# 安全配置
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=*

# 监控配置
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_PASSWORD=admin

# 邮件通知
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-email-password
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=admin@example.com

# 定时任务
SCHEDULE_ENABLED=true
SCHEDULE_INTERVAL=3600  # 1小时

# 功能开关
FEATURE_PARALLEL=true
FEATURE_CACHE=true
FEATURE_NOTIFICATIONS=false
FEATURE_MONITORING=true

# Docker配置
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=your-docker-username
DOCKER_PASSWORD=your-docker-password